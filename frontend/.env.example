# qontext-frontend-v2 environment configuration
#
# Copy to `.env.local` and adjust per environment.

# Base URL of the qontext FastAPI backend (api/server.py).
# Default matches `python run_qontext_api.py` in dev.
VITE_API_BASE_URL=http://127.0.0.1:8000

# When set to "true" the conflict review screen reads from the bundled
# mock data in src/lib/qontext-data.ts instead of calling the backend.
# Useful for offline UI work and storyboard demos.
VITE_USE_MOCKS=false
